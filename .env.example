# ══════════════════════════════════════════════════
# BIACP Dashboard — Variables de Entorno
# ══════════════════════════════════════════════════

# ── Base de datos PostgreSQL ──
DB_PASSWORD=cambiar_por_password_seguro
DATABASE_URL=postgresql://biacp:${DB_PASSWORD}@db:5432/biacp

# ── Azure AD / Microsoft Entra ID (Dashboard MSAL) ──
AZURE_CLIENT_ID=0348c2e2-01d0-4b98-bbce-90efa94d7982
AZURE_TENANT_ID=cbc2d319-22d3-4f27-8179-2e3c17387677

# ── Redirect URI (producción) ──
REDIRECT_URI=https://bi.acp.com.co

# ── ETL: Azure AD App-Only Auth (para descargar de SharePoint sin usuario) ──
ETL_CLIENT_ID=<nuevo-app-registration-id>
ETL_CLIENT_SECRET=<client-secret-generado>
